<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">

    <persistence-unit name="mariadb-pu">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>server.entity.SanPham</class>
        <class>server.entity.MaVachSanPham</class>
        <class>server.entity.KhuyenMai</class>
        <class>server.entity.KhuyenMaiSanPham</class>
        <class>server.entity.CaLam</class>
        <class>server.entity.ChiTietPhieuNhap</class>
        <class>server.entity.LichSuCaLam</class>
        <class>server.entity.LoSanPham</class>
        <class>server.entity.NhaCungCap</class>
        <class>server.entity.NhanVien</class>
        <class>server.entity.SanPhamCungCap</class>
        <class>server.entity.TaiKhoan</class>
        <class>server.entity.PhieuNhap</class>
        <class>server.entity.LichSuLo</class>
        <class>server.entity.ChiTietHoaDon</class>
        <class>server.entity.HoaDon</class>
        <class>server.entity.KhachHang</class>
        <class>server.entity.ChiTietPhieuTraHang</class>
        <class>server.entity.PhieuTraHang</class>
        <class>server.entity.ChiTietXuatLo</class>
        <class>server.entity.DonViTinh</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver"
                      value="org.mariadb.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mariadb://localhost:3306/nhathuocduocankhang"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password"
                      value="root"/>
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MariaDBDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>
